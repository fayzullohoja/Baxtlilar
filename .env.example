# ============================================================
# Bakhtlilar — local environment template
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` — it's in .gitignore.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role key — bypasses RLS, used only server-side
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Auth (required) ──────────────────────────────────────────
# 32+ random chars — used to sign session JWT
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# ── Telegram (required for production) ───────────────────────
# Get from: @BotFather → /newbot or your existing bot
TELEGRAM_BOT_TOKEN=

# Bot username (without @) — used in error messages directing users to TG
BOT_USERNAME=baxtlilar_uz_bot

# Support TG username (without @) — shown in /blocked + bot /help replies
SUPPORT_TG_USERNAME=baxtlilar_support

# Webhook verification secret — set when calling Telegram setWebhook
TELEGRAM_WEBHOOK_SECRET=

# Browser dev: skip HMAC validation of Telegram initData → fake user.
# In production, must be unset or "0".
DEV_BYPASS_TG=1

# (Optional) Your personal Telegram chat ID — admin notifications go here.
# Get yours by sending /start to @userinfobot
ADMIN_TG_CHAT_ID=

# ── SMS / OTP ────────────────────────────────────────────────
# "mock" = code logged to console + "123456" always accepted (dev)
# real provider keys (Eskiz / Playmobile / Twilio) — TODO
SMS_PROVIDER=mock

# ── Admin panel (required) ───────────────────────────────────
# Long random string — single shared secret for /admin/* access
# Generate same way as SESSION_SECRET. Then put in Vercel env for prod.
ADMIN_SECRET=

# ── App URL ──────────────────────────────────────────────────
# Used in TG notification deep-links. Production = https://baxtlilar.vercel.app
APP_URL=http://localhost:3000

# ── Test-only overrides ──────────────────────────────────────
# Bypass OTP rate-limit during integration tests. Honored only when
# NODE_ENV !== "production".
# OTP_DISABLE_RATE_LIMIT=1
